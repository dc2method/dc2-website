---
import { getLocale, t } from '../utils/i18n';

const currentLocale = getLocale(Astro.url);
const currentYear = new Date().getFullYear();

const introLink = currentLocale === 'fr' ? '/intro' : '/en/intro';
const licenceLink = currentLocale === 'fr' ? '/licence' : '/en/licence';
const aboutLink = currentLocale === 'fr' ? '/about' : '/en/about';
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-grid">
      <!-- Column 1: About -->
      <div class="footer-column">
        <h3 class="footer-heading">DC²</h3>
        <p class="footer-description">
          {currentLocale === 'fr'
            ? 'Méthodologie structurée pour développement logiciel assisté par LLM'
            : 'Structured methodology for LLM-assisted software development'
          }
        </p>
      </div>

      <!-- Column 2: Methodology -->
      <div class="footer-column">
        <h3 class="footer-heading">{t('footer.methodology', currentLocale)}</h3>
        <ul class="footer-links">
          <li><a href={introLink}>
            {currentLocale === 'fr' ? 'Introduction' : 'Introduction'}
          </a></li>
          <li><a href={currentLocale === 'fr' ? '/phase1-architecture-strategique' : '/en/phase1-architecture-strategique'}>
            {currentLocale === 'fr' ? 'Phase 1 : Architecture' : 'Phase 1: Architecture'}
          </a></li>
          <li><a href={currentLocale === 'fr' ? '/phase3-tdd-red' : '/en/phase3-tdd-red'}>
            {currentLocale === 'fr' ? 'Phase 3 : TDD RED' : 'Phase 3: TDD RED'}
          </a></li>
        </ul>
      </div>

      <!-- Column 3: Resources -->
      <div class="footer-column">
        <h3 class="footer-heading">{t('footer.resources', currentLocale)}</h3>
        <ul class="footer-links">
          <li><a href={aboutLink}>{t('footer.about', currentLocale)}</a></li>
          <li><a href={licenceLink}>{t('footer.license', currentLocale)}</a></li>

        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        © {currentYear} {t('footer.created-by', currentLocale)}
        <a href={aboutLink} class="footer-author">Eric Gauthier</a>
      </p>
      <p class="footer-license">
        <a href={licenceLink}>{t('footer.license', currentLocale)}</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--dd-primary);
    color: rgba(255, 255, 255, 0.9);
    margin-top: auto;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--space-12) var(--space-6) var(--space-6);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .footer-column {
    display: flex;
    flex-direction: column;
  }

  .footer-heading {
    font-family: var(--font-family-heading);
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--dd-white);
    margin-bottom: var(--space-4);
  }

  .footer-description {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: rgba(255, 255, 255, 0.7);
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links li {
    margin-bottom: var(--space-3);
  }

  .footer-links a {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .footer-links a:hover {
    color: var(--dd-secondary);
    text-decoration: underline;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-6);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: var(--font-size-sm);
  }

  .footer-copyright {
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  .footer-author {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .footer-author:hover {
    color: var(--dd-secondary);
    text-decoration: underline;
  }

  .footer-license {
    margin: 0;
  }

  .footer-license a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .footer-license a:hover {
    color: var(--dd-secondary);
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer-container {
      padding: var(--space-8) var(--space-4) var(--space-4);
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--space-3);
      text-align: center;
    }
  }
</style>
