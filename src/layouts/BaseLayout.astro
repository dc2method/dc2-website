---
import LanguageDetector from '../components/LanguageDetector.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// Self-hosted fonts for privacy and performance
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'fr' | 'en';
  showNavbar?: boolean;
  showFooter?: boolean;
}

const {
  title,
  description = 'Structured LLM Development',
  lang = 'fr',
  showNavbar = true,
  showFooter = true
} = Astro.props;

const siteUrl = 'https://dc2method.dev';
const currentPath = Astro.url.pathname;
const canonicalUrl = `${siteUrl}${currentPath}`;
const isFrench = lang === 'fr';
const alternatePath = isFrench
  ? currentPath.replace(/^\/fr/, '') || '/'
  : `/fr${currentPath}`;
const alternateUrl = `${siteUrl}${alternatePath}`;
const enUrl = isFrench ? alternateUrl : canonicalUrl;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: 'DC²',
      url: siteUrl,
      logo: `${siteUrl}/favicon.png`,
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'DC² — Développement par Contraintes Convergentes',
      publisher: { '@id': `${siteUrl}/#organization` },
      inLanguage: ['fr', 'en'],
    },
  ],
};
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={isFrench ? 'en' : 'fr'} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/img/og-image.png`} />
    <meta property="og:locale" content={isFrench ? 'fr_FR' : 'en_US'} />
    <meta property="og:locale:alternate" content={isFrench ? 'en_US' : 'fr_FR'} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={`${siteUrl}/img/og-image.png`} />

    <!-- Structured Data / JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <LanguageDetector />
  </head>
  <body>
    {showNavbar && <Navbar />}
    <slot />
    {showFooter && <Footer />}
  </body>
</html>

<style is:global>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
</style>
