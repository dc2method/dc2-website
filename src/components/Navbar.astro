---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLocale, t } from '../utils/i18n';

const currentLocale = getLocale(Astro.url);
const methodologyLink = currentLocale === 'fr' ? '/fr/intro' : '/intro';
const aboutLink = currentLocale === 'fr' ? '/fr/about' : '/about';
const homeLink = currentLocale === 'fr' ? '/fr/' : '/';
---

<nav class="navbar">
  <div class="navbar-container">
    <a href={homeLink} class="navbar-logo">
      <span class="logo-text">DC<span class="logo-separator">²</span>
        {currentLocale === 'fr'
          ? 'Développement par Contraintes Convergentes'
          : 'Development by Convergent Constraints'
        }
      </span>
      <span class="logo-tagline">{t('hero.tagline', currentLocale)}</span>
    </a>

    <div class="navbar-menu">
      <a href={methodologyLink} class="navbar-link">
        {t('nav.methodology', currentLocale)}
      </a>
      <a href={aboutLink} class="navbar-link">
        {t('nav.about', currentLocale)}
      </a>
      <div class="navbar-lang">
        <LanguageSwitcher />
      </div>
    </div>
  </div>
</nav>

<style>
  .navbar {
    background: var(--dd-primary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px var(--dd-shadow);
  }

  .navbar-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--space-4) var(--space-6);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .navbar-logo {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: opacity var(--transition-base);
  }

  .navbar-logo:hover {
    opacity: 0.8;
  }

  .logo-text {
    font-family: var(--font-family-heading);
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--dd-white);
    letter-spacing: 0.5px;
  }

  .logo-separator {
    color: var(--dd-secondary);
    margin: 0 2px;
  }

  .logo-tagline {
    font-family: var(--font-family-body);
    font-size: var(--font-size-xs);
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 2px;
  }

  .navbar-menu {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .navbar-link {
    font-family: var(--font-family-body);
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--dd-white);
    text-decoration: none;
    transition: color var(--transition-base);
    padding: var(--space-2) 0;
    border-bottom: 2px solid transparent;
  }

  .navbar-link:hover {
    color: var(--dd-secondary);
    border-bottom-color: var(--dd-secondary);
    text-decoration: none;
  }

  .navbar-lang {
    margin-left: var(--space-4);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .navbar-container {
      flex-direction: column;
      gap: var(--space-4);
      padding: var(--space-3) var(--space-4);
    }

    .navbar-menu {
      width: 100%;
      justify-content: center;
      gap: var(--space-4);
    }

    .logo-text {
      font-size: var(--font-size-lg);
    }

    .navbar-link {
      font-size: var(--font-size-sm);
    }
  }
</style>
