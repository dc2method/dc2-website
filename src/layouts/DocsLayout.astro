---
import BaseLayout from './BaseLayout.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { getCollection } from 'astro:content';
import { getLocale } from '../utils/i18n';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentLocale = getLocale(Astro.url);
const currentSlug = Astro.url.pathname.replace(/^\/(en\/)?/, '').replace(/\/$/, '');

// Get all docs for current locale and sort by sidebar_position
const allDocs = await getCollection('docs', ({ data }) => data.lang === currentLocale);
const sortedDocs = allDocs.sort((a, b) => {
  const posA = a.data.sidebar_position ?? 999;
  const posB = b.data.sidebar_position ?? 999;
  return posA - posB;
});
---

<BaseLayout title={title} description={description} lang={currentLocale}>
  <div class="docs-layout">
    <aside class="sidebar">
      <div class="sidebar-header">
        <a href={currentLocale === 'fr' ? '/' : '/en/'} class="logo">
          DocDriven
        </a>
        <div class="language-switcher-container">
          <LanguageSwitcher />
        </div>
      </div>
      <nav class="sidebar-nav">
        <ul>
          {sortedDocs.map((doc) => {
            const docSlug = doc.slug.replace(/^(fr|en)\//, '');
            const isActive = currentSlug === docSlug || currentSlug === doc.slug;
            const href = currentLocale === 'fr' ? `/${docSlug}` : `/en/${docSlug}`;

            return (
              <li>
                <a href={href} class:list={['sidebar-link', { active: isActive }]}>
                  {doc.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    </aside>

    <main class="docs-content">
      <article>
        <slot />
      </article>
    </main>
  </div>
</BaseLayout>

<style>
  .docs-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
    max-width: 1400px;
    margin: 0 auto;
  }

  .sidebar {
    background: var(--dd-neutral-light, #F0F4F8);
    border-right: 1px solid #e0e0e0;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    padding: 1.5rem 0;
  }

  .sidebar-header {
    padding: 0 1.5rem 1.5rem;
    border-bottom: 1px solid #e0e0e0;
    margin-bottom: 1.5rem;
  }

  .logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--dd-primary, #1A2332);
    text-decoration: none;
    display: block;
    margin-bottom: 1rem;
  }

  .logo:hover {
    color: var(--dd-secondary, #2E86AB);
  }

  .language-switcher-container {
    display: flex;
    justify-content: flex-start;
  }

  .sidebar-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-nav li {
    margin: 0;
  }

  .sidebar-link {
    display: block;
    padding: 0.5rem 1.5rem;
    color: var(--dd-neutral-dark, #2C3E50);
    text-decoration: none;
    font-size: 0.9rem;
    transition: background 0.2s, color 0.2s;
  }

  .sidebar-link:hover {
    background: rgba(46, 134, 171, 0.1);
    color: var(--dd-secondary, #2E86AB);
  }

  .sidebar-link.active {
    background: var(--dd-secondary, #2E86AB);
    color: white;
    font-weight: 600;
  }

  .docs-content {
    padding: 2rem 3rem;
    max-width: 900px;
  }

  .docs-content article {
    line-height: 1.7;
  }

  .docs-content article :global(h1) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    color: var(--dd-primary, #1A2332);
  }

  .docs-content article :global(h2) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.75rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--dd-primary, #1A2332);
  }

  .docs-content article :global(h3) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--dd-neutral-dark, #2C3E50);
  }

  .docs-content article :global(p) {
    margin-bottom: 1rem;
  }

  .docs-content article :global(code) {
    font-family: 'JetBrains Mono', monospace;
    background: var(--dd-code-bg, #282C34);
    color: #61dafb;
    padding: 0.2rem 0.4rem;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .docs-content article :global(pre) {
    background: var(--dd-code-bg, #282C34);
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .docs-content article :global(pre code) {
    background: none;
    padding: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: relative;
      height: auto;
      border-right: none;
      border-bottom: 1px solid #e0e0e0;
    }

    .docs-content {
      padding: 1.5rem 1rem;
    }
  }
</style>
